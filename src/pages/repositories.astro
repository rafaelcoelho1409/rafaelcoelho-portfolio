---
import Base from "../layouts/Base.astro";
import StackBadge from "../components/StackBadge.astro";
import { REPOS, GITHUB_USERNAME } from "../data/repositories";
import { GITHUB_STATS, GITHUB_STATS_AS_OF, TOP_LANGUAGES } from "../data/githubStats";

const STATS_BG = "0a0a0a";
const STATS_TITLE = "d4b572";
const STATS_TEXT = "cccccc";
const STATS_BORDER = "4a3a1f";

const streakUrl = `https://github-readme-streak-stats.herokuapp.com/?user=${GITHUB_USERNAME}&background=${STATS_BG}&stroke=${STATS_BORDER}&ring=${STATS_TITLE}&fire=${STATS_TITLE}&currStreakLabel=${STATS_TITLE}&sideLabels=${STATS_TEXT}&dates=${STATS_TEXT}&currStreakNum=${STATS_TEXT}&sideNums=${STATS_TEXT}&hide_border=false`;
const trophyUrl = `https://github-trophies.vercel.app/?username=${GITHUB_USERNAME}&theme=darkhub&no-frame=false&row=2&column=4&margin-w=8&margin-h=8`;

const grouped = REPOS.reduce<Record<number, typeof REPOS>>((acc, r) => {
  (acc[r.year] ||= []).push(r);
  return acc;
}, {});

const years = Object.keys(grouped)
  .map((y) => Number(y))
  .sort((a, b) => b - a);
---

<Base
  title="Repositories"
  description="GitHub repositories — every public project I've shipped, grouped by year, with key tooling per repo."
>
  <div class="container-page">
    <header class="mb-12 pt-4">
      <p class="eyebrow mb-4">/ Repositories</p>
      <h1
        class="font-display mb-4 text-[2.4rem] font-medium tracking-tight"
        style="color: var(--color-text); letter-spacing: -0.025em;"
      >
        Public repositories
      </h1>
      <p class="text-[16px] leading-[1.7]" style="color: var(--color-text-muted);">
        Every public GitHub project I've shipped, grouped by release year. Stats below
        reflect GitHub activity.
      </p>
    </header>

    <section class="mb-16">
      <h2 class="label-mono mb-5">GitHub activity</h2>
      <div style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px;">
        <a
          href={`https://github.com/${GITHUB_USERNAME}`}
          target="_blank"
          rel="noreferrer noopener"
          class="block rounded-sm border p-5 transition-colors hover:border-[var(--color-gold)]"
          style="border-color: var(--color-border); background-color: var(--color-bg-2);"
        >
          <div class="mb-4 flex items-baseline justify-between">
            <span class="font-mono text-[11px] tracking-[0.14em] uppercase" style="color: var(--color-platinum-dim);">
              {GITHUB_USERNAME}'s GitHub stats
            </span>
            <span class="font-mono text-[10px] tracking-tight" style="color: var(--color-text-dim);">
              as of {GITHUB_STATS_AS_OF}
            </span>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <div class="font-display text-[1.8rem] font-semibold tracking-tight" style="color: var(--color-gold);">
                {GITHUB_STATS.publicRepos}
              </div>
              <div class="text-[12.5px]" style="color: var(--color-text-muted);">Public repos</div>
            </div>
            <div>
              <div class="font-display text-[1.8rem] font-semibold tracking-tight" style="color: var(--color-gold);">
                {GITHUB_STATS.followers}
              </div>
              <div class="text-[12.5px]" style="color: var(--color-text-muted);">Followers</div>
            </div>
            <div>
              <div class="font-display text-[1.8rem] font-semibold tracking-tight" style="color: var(--color-gold);">
                {GITHUB_STATS.totalStars}
              </div>
              <div class="text-[12.5px]" style="color: var(--color-text-muted);">Total stars</div>
            </div>
            <div>
              <div class="font-display text-[1.8rem] font-semibold tracking-tight" style="color: var(--color-gold);">
                {GITHUB_STATS.memberSince}
              </div>
              <div class="text-[12.5px]" style="color: var(--color-text-muted);">Member since</div>
            </div>
          </div>
        </a>
        <a
          href={`https://github.com/${GITHUB_USERNAME}?tab=repositories`}
          target="_blank"
          rel="noreferrer noopener"
          class="block rounded-sm border p-5 transition-colors hover:border-[var(--color-gold)]"
          style="border-color: var(--color-border); background-color: var(--color-bg-2);"
        >
          <div class="mb-4 flex items-baseline justify-between">
            <span class="font-mono text-[11px] tracking-[0.14em] uppercase" style="color: var(--color-platinum-dim);">
              Most used languages
            </span>
            <span class="font-mono text-[10px] tracking-tight" style="color: var(--color-text-dim);">
              as of {GITHUB_STATS_AS_OF}
            </span>
          </div>
          <div class="space-y-2.5">
            {
              TOP_LANGUAGES.map((lang) => (
                <div>
                  <div class="mb-1 flex items-baseline justify-between text-[12.5px]">
                    <span style="color: var(--color-text);">{lang.name}</span>
                    <span class="font-mono" style="color: var(--color-platinum-dim);">
                      {lang.percent.toFixed(1)}%
                    </span>
                  </div>
                  <div class="h-[5px] w-full rounded-full" style="background-color: var(--color-border);">
                    <div
                      class="h-full rounded-full"
                      style={`width: ${lang.percent}%; background-color: var(--color-gold);`}
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </a>
        <a
          href={`https://github.com/${GITHUB_USERNAME}`}
          target="_blank"
          rel="noreferrer noopener"
          class="block overflow-hidden rounded-sm border transition-colors hover:border-[var(--color-gold)]"
          style="border-color: var(--color-border);"
        >
          <img
            src={streakUrl}
            alt={`${GITHUB_USERNAME} contribution streak`}
            class="block w-full"
            loading="lazy"
            decoding="async"
          />
        </a>
        <a
          href={`https://github.com/${GITHUB_USERNAME}`}
          target="_blank"
          rel="noreferrer noopener"
          class="block overflow-hidden rounded-sm border transition-colors hover:border-[var(--color-gold)]"
          style="border-color: var(--color-border); background-color: var(--color-bg-2);"
        >
          <img
            src={trophyUrl}
            alt={`${GITHUB_USERNAME} GitHub trophies`}
            class="block w-full"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
    </section>

    <div class="hairline-gold mb-12" style="opacity: 0.35;"></div>

    <section>
      <h2 class="label-mono mb-7">Repositories by year</h2>
      <div class="space-y-16">
        {
          years.map((year) => (
            <div class="pt-4">
              <div class="mb-6 flex items-baseline gap-4">
                <span
                  class="font-display font-bold tracking-tight"
                  style="font-size: clamp(28px, 3vw, 40px); color: var(--color-gold); letter-spacing: -0.025em; line-height: 1;"
                >
                  {year}
                </span>
                <span
                  class="font-mono text-[11px] tracking-[0.14em] uppercase"
                  style="color: var(--color-platinum-dim);"
                >
                  {grouped[year].length} {grouped[year].length === 1 ? "repo" : "repos"}
                </span>
              </div>
              <div class="grid grid-cols-1 gap-3">
                {grouped[year].map((r) => (
                  <article
                    class="rounded-sm border p-5"
                    style="border-color: var(--color-border); background-color: var(--color-bg-2);"
                  >
                    <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
                      <h3
                        class="font-display text-[17px] font-semibold tracking-tight"
                        style="color: var(--color-text); letter-spacing: -0.015em;"
                      >
                        {r.projectName}
                      </h3>
                      <span
                        class="font-mono text-[10.5px] tracking-[0.14em] whitespace-nowrap uppercase"
                        style="color: var(--color-platinum-dim);"
                      >
                        {r.releaseDate}
                      </span>
                    </div>

                    <div class="mb-4 flex flex-wrap gap-x-4 gap-y-1 font-mono text-[11.5px] tracking-tight">
                      <a
                        href={`https://github.com/${r.repo}`}
                        target="_blank"
                        rel="noreferrer noopener"
                        class="transition-colors hover:text-[var(--color-gold)]"
                        style="color: var(--color-gold-dim);"
                      >
                        github.com/{r.repo} ↗
                      </a>
                      {r.caseStudy && (
                        <a
                          href={r.caseStudy}
                          class="transition-colors hover:text-[var(--color-gold)]"
                          style="color: var(--color-gold-dim);"
                        >
                          Case study →
                        </a>
                      )}
                    </div>

                    <div class="flex flex-wrap gap-1.5">
                      {r.keyTools.map((t) => (
                        <StackBadge name={t} />
                      ))}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</Base>
