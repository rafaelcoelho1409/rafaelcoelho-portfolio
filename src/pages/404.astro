---
import Base from "../layouts/Base.astro";
---

<Base title="404" description="Page not found." noindex>
  <div class="container-page py-20 text-center">
    <p class="eyebrow mb-4">404</p>
    <h1
      class="font-display mb-4 text-[2.4rem] font-medium tracking-tight"
      style="color: var(--color-text); letter-spacing: -0.025em;"
    >
      Not found
    </h1>
    <p
      class="mx-auto mb-10 max-w-md text-[15.5px] leading-[1.7]"
      style="color: var(--color-text-muted);"
    >
      That page doesn't exist — or it moved when this site migrated from Jekyll to
      Astro. Try the links below.
    </p>
    <div class="flex flex-wrap justify-center gap-2.5 font-mono text-[12.5px] tracking-tight">
      <a
        href="/"
        class="rounded-sm border px-3 py-1.5 transition-colors hover:border-[var(--color-gold)] hover:text-[var(--color-gold)]"
        style="border-color: var(--color-border-strong); color: var(--color-text);">Home</a
      >
      <a
        href="/work"
        class="rounded-sm border px-3 py-1.5 transition-colors hover:border-[var(--color-gold)] hover:text-[var(--color-gold)]"
        style="border-color: var(--color-border-strong); color: var(--color-text);">Work</a
      >
      <a
        href="/writing"
        class="rounded-sm border px-3 py-1.5 transition-colors hover:border-[var(--color-gold)] hover:text-[var(--color-gold)]"
        style="border-color: var(--color-border-strong); color: var(--color-text);">Writing</a
      >
    </div>
  </div>
</Base>
