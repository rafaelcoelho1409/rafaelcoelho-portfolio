---
import Base from "../layouts/Base.astro";
---

<Base title="404" description="Page not found." noindex>
  <div class="container-page py-20 text-center">
    <p class="mb-3 font-mono text-[12px]" style="color: var(--color-accent);">404</p>
    <h1 class="mb-3 text-3xl font-semibold tracking-tight" style="color: var(--color-text);">
      Not found
    </h1>
    <p class="mx-auto mb-8 max-w-md text-[15px]" style="color: var(--color-text-muted);">
      That page doesn't exist — or it moved when this site migrated from Jekyll to Astro. Try the
      links below.
    </p>
    <div class="flex flex-wrap justify-center gap-3 font-mono text-[13px]">
      <a
        href="/"
        class="rounded border px-3 py-1.5 transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        style="border-color: var(--color-border-strong); color: var(--color-text);">Home</a
      >
      <a
        href="/work"
        class="rounded border px-3 py-1.5 transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        style="border-color: var(--color-border-strong); color: var(--color-text);">Work</a
      >
      <a
        href="/writing"
        class="rounded border px-3 py-1.5 transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        style="border-color: var(--color-border-strong); color: var(--color-text);">Writing</a
      >
    </div>
  </div>
</Base>
