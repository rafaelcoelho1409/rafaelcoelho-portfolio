---
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base
  title="Writing"
  description="Technical writing on MLOps, real-time ML, Generative AI, and production ML systems by Rafael Coelho."
>
  <div class="container-page">
    <header class="mb-12 pt-4">
      <p class="eyebrow mb-4">/ Writing</p>
      <h1
        class="font-display mb-4 text-[2.4rem] font-medium tracking-tight"
        style="color: var(--color-text); letter-spacing: -0.025em;"
      >
        Writing
      </h1>
      <p class="text-[16px] leading-[1.7]" style="color: var(--color-text-muted);">
        Notes on MLOps, real-time ML, Generative AI, and the production systems behind them.
      </p>
    </header>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-dim);">No posts yet.</p>
    ) : (
      <div>
        {posts.map((p) => (
          <PostCard
            title={p.data.title}
            summary={p.data.summary}
            href={`/writing/${p.id}`}
            date={p.data.date}
            tags={p.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</Base>
