---
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base
  title="Writing"
  description="Technical writing on MLOps, real-time ML, Generative AI, and production ML systems by Rafael Coelho."
>
  <div class="container-page">
    <header class="mb-10">
      <p class="mb-2 font-mono text-[12px]" style="color: var(--color-accent);">/ writing</p>
      <h1 class="mb-3 text-3xl font-semibold tracking-tight" style="color: var(--color-text);">
        Writing
      </h1>
      <p class="text-[15px] leading-7" style="color: var(--color-text-muted);">
        Notes on MLOps, real-time ML, Generative AI, and the production systems behind them.
      </p>
    </header>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-dim);">No posts yet.</p>
    ) : (
      <div>
        {posts.map((p) => (
          <PostCard
            title={p.data.title}
            summary={p.data.summary}
            href={`/writing/${p.id}`}
            date={p.data.date}
            tags={p.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</Base>
