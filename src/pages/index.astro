---
import Base from "../layouts/Base.astro";
import MetricTile from "../components/MetricTile.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";
import { SITE, HOME_METRICS } from "../consts";

const allWork = (await getCollection("work", ({ data }) => !data.draft)).sort(
  (a, b) =>
    a.data.order - b.data.order || b.data.date.valueOf() - a.data.date.valueOf(),
);
const featured = allWork.filter((w) => w.data.featured).slice(0, 4);
const featuredList = featured.length > 0 ? featured : allWork.slice(0, 4);

const recentPosts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base>
  <div class="container-page">
    <section class="mb-20 pt-8 sm:mb-24 sm:pt-14">
      <p class="eyebrow mb-5">{SITE.tagline}</p>
      <h1
        class="font-display mb-6 text-[2.25rem] leading-[1.12] font-medium tracking-tight sm:text-[3.25rem]"
        style="color: var(--color-text); letter-spacing: -0.03em;"
      >
        Production AI systems on Kubernetes — from real-time
        <span style="color: var(--color-gold); font-style: italic;"
          >incremental</span
        > pipelines to adaptive agentic RAG.
      </h1>
      <p class="text-[17px] leading-[1.7]" style="color: var(--color-text-muted);">
        Six years shipping end-to-end ML platforms — Kafka, Spark, full GitOps, 50+
        production metrics. Building <a
          href="/work/coelho-nexus"
          class="font-medium transition-colors hover:text-[var(--color-gold)]"
          style="color: var(--color-text); border-bottom: 1px solid var(--color-gold); padding-bottom: 1px;"
          >COELHO Nexus</a
        > — adaptive Agentic RAG with a multi-provider Pareto-bandit LLM rotator,
        two-stage retrieval, GraphRAG via Neo4j, and full observability via
        OpenTelemetry · Alloy · LGTM.
      </p>

      <div class="mt-8 flex flex-wrap gap-2.5">
        <span
          class="rounded-full border px-3 py-1 font-mono text-[10.5px] tracking-[0.14em] uppercase"
          style="border-color: var(--color-border-strong); color: var(--color-platinum);"
        >
          {SITE.location}
        </span>
        <span
          class="rounded-full border px-3 py-1 font-mono text-[10.5px] tracking-[0.14em] uppercase"
          style="border-color: var(--color-gold-deep); color: var(--color-gold);"
        >
          Open · UAE · KSA · Qatar · Singapore · USA
        </span>
      </div>
    </section>

    <div class="hairline-gold mb-20"></div>

    <section class="mb-20">
      <p class="eyebrow mb-6">By the numbers</p>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        {
          HOME_METRICS.map((m) => (
            <MetricTile value={m.value} unit={m.unit} label={m.label} />
          ))
        }
      </div>
    </section>

    <section class="mb-20">
      <div class="mb-6 flex items-baseline justify-between">
        <p class="eyebrow">Selected work</p>
        <a
          href="/work"
          class="font-mono text-[11px] tracking-[0.14em] uppercase transition-colors hover:text-[var(--color-gold)]"
          style="color: var(--color-platinum-dim);">All work →</a
        >
      </div>
      <div class="grid grid-cols-1 gap-3">
        {
          featuredList.map((entry) => (
            <ProjectCard
              title={entry.data.title}
              summary={entry.data.summary}
              outcome={entry.data.outcome}
              href={`/work/${entry.id}`}
              stack={entry.data.stack}
              date={entry.data.date}
              featured={entry.data.featured}
            />
          ))
        }
      </div>
    </section>

    {recentPosts.length > 0 && (
      <section class="mb-16">
        <div class="mb-4 flex items-baseline justify-between">
          <p class="eyebrow">Recent writing</p>
          <a
            href="/writing"
            class="font-mono text-[11px] tracking-[0.14em] uppercase transition-colors hover:text-[var(--color-gold)]"
            style="color: var(--color-platinum-dim);"
          >
            All writing →
          </a>
        </div>
        <div>
          {recentPosts.map((p) => (
            <PostCard
              title={p.data.title}
              summary={p.data.summary}
              href={`/writing/${p.id}`}
              date={p.data.date}
              tags={p.data.tags}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>
