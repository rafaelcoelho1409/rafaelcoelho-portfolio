---
import Base from "../layouts/Base.astro";
import MetricTile from "../components/MetricTile.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import portrait from "../assets/photos/profile1.png";
import { SITE, HOME_METRICS } from "../consts";

const allWork = (await getCollection("work", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featured = allWork.filter((w) => w.data.featured);
const rest = allWork.filter((w) => !w.data.featured);
const featuredList = [...featured, ...rest].slice(0, 4);

const recentPosts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base>
  <div class="container-page">
    <section class="mb-20 pt-8 sm:mb-24 sm:pt-14">
      <p class="eyebrow mb-5">{SITE.tagline}</p>
      <h1
        class="font-display mb-8 text-[2.25rem] leading-[1.12] font-medium tracking-tight sm:text-[3.25rem]"
        style="color: var(--color-text); letter-spacing: -0.03em;"
      >
        Production AI systems on Kubernetes — from real-time incremental
        pipelines to adaptive
        <span style="color: var(--color-gold); font-style: italic;"
          >agentic</span
        > RAG.
      </h1>

      <div
        class="flex flex-col-reverse items-start gap-7 sm:flex-row sm:items-start sm:gap-8"
      >
        <div class="min-w-0 flex-1">
          <p
            class="text-[17px] leading-[1.7]"
            style="color: var(--color-text-muted);"
          >
            Six years engineering production ML systems end to end — Kafka
            and Spark pipelines, full GitOps delivery. Architect of <a
              href="/work/coelho-nexus"
              class="font-medium transition-colors hover:text-[var(--color-gold)]"
              style="color: var(--color-text); border-bottom: 1px solid var(--color-gold); padding-bottom: 1px;"
              >COELHO Nexus</a
            >, a Kubernetes-native platform running three production agentic
            AI features on one self-learning LLM rotator, evaluation-gated
            pipelines, and full observability via LangFuse · OpenTelemetry ·
            Alloy · LGTM — at $0 inference cost.
          </p>

          <div class="mt-8 flex flex-wrap gap-2.5">
            <span
              class="rounded-full border px-3 py-1 font-mono text-[10.5px] tracking-[0.14em] uppercase"
              style="border-color: var(--color-border-strong); color: var(--color-platinum);"
            >
              {SITE.location}
            </span>
            <span
              class="rounded-full border px-3 py-1 font-mono text-[10.5px] tracking-[0.14em] uppercase"
              style="border-color: var(--color-gold-deep); color: var(--color-gold);"
            >
              {SITE.relocation}
            </span>
          </div>
        </div>

        <div class="shrink-0 sm:mt-1">
          <Image
            src={portrait}
            alt="Rafael Coelho"
            width={200}
            height={200}
            densities={[2, 3]}
            loading="eager"
            quality={100}
            format="avif"
            class="block rounded-sm"
            style="width: 200px; height: 200px; object-fit: cover; object-position: center 22%; border: 1px solid var(--color-gold-dim); box-shadow: 0 6px 22px oklch(0 0 0 / 0.5);"
          />
        </div>
      </div>
    </section>

    <div class="hairline-gold mb-20"></div>

    <section class="mb-20">
      <p class="eyebrow mb-6">By the numbers</p>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        {
          HOME_METRICS.map((m) => (
            <MetricTile value={m.value} unit={m.unit} label={m.label} />
          ))
        }
      </div>
    </section>

    <section class="mb-20">
      <div class="mb-6 flex items-baseline justify-between">
        <p class="eyebrow">Selected work</p>
        <a
          href="/work"
          class="font-mono text-[11px] tracking-[0.14em] uppercase transition-colors hover:text-[var(--color-gold)]"
          style="color: var(--color-platinum-dim);">All work →</a
        >
      </div>
      <div class="grid grid-cols-1 gap-3">
        {
          featuredList.map((entry, i) => (
            <ProjectCard
              title={entry.data.title}
              summary={entry.data.summary}
              outcome={entry.data.outcome}
              href={`/work/${entry.id}`}
              stack={entry.data.stack}
              date={entry.data.date}
              featured={entry.data.featured}
              thumbnail={entry.data.thumbnail}
              eager={i === 0}
            />
          ))
        }
      </div>
    </section>

    {recentPosts.length > 0 && (
      <section class="mb-16">
        <div class="mb-4 flex items-baseline justify-between">
          <p class="eyebrow">Recent writing</p>
          <a
            href="/writing"
            class="font-mono text-[11px] tracking-[0.14em] uppercase transition-colors hover:text-[var(--color-gold)]"
            style="color: var(--color-platinum-dim);"
          >
            All writing →
          </a>
        </div>
        <div>
          {recentPosts.map((p) => (
            <PostCard
              title={p.data.title}
              summary={p.data.summary}
              href={`/writing/${p.id}`}
              date={p.data.date}
              tags={p.data.tags}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>
