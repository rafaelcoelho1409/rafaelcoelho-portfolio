---
import Base from "../layouts/Base.astro";
import { SITE, SOCIALS } from "../consts";
---

<Base title="Contact" description={`Get in touch with ${SITE.author}.`}>
  <div class="container-page">
    <header class="mb-12 pt-4">
      <p class="eyebrow mb-4">/ Contact</p>
      <h1
        class="font-display mb-4 text-[2.4rem] font-medium tracking-tight"
        style="color: var(--color-text); letter-spacing: -0.025em;"
      >
        Get in touch
      </h1>
      <p class="text-[16px] leading-[1.7]" style="color: var(--color-text-muted);">
        Best for: Senior MLOps / ML / LLMOps engineering roles, agentic AI consulting,
        paid speaking or workshops. I read every message; reply within 48 hours.
      </p>
    </header>

    <div class="hairline-gold mb-10" style="opacity: 0.35;"></div>

    <section class="mb-12">
      <h2 class="label-mono mb-6">Channels</h2>
      <ul class="space-y-0">
        <li
          class="flex items-baseline justify-between gap-4 border-b py-4"
          style="border-color: var(--color-border);"
        >
          <div>
            <div
              class="font-display text-[16px]"
              style="color: var(--color-text);"
            >
              Email
            </div>
            <div class="font-mono text-[11px] tracking-tight" style="color: var(--color-text-dim);">
              Fastest. Default to this.
            </div>
          </div>
          <a
            href={SOCIALS.email}
            class="font-mono text-[12.5px] tracking-tight transition-colors hover:text-[var(--color-gold)]"
            style="color: var(--color-text);"
          >
            {SITE.email} ↗
          </a>
        </li>
        <li
          class="flex items-baseline justify-between gap-4 border-b py-4"
          style="border-color: var(--color-border);"
        >
          <div>
            <div
              class="font-display text-[16px]"
              style="color: var(--color-text);"
            >
              GitHub
            </div>
            <div class="font-mono text-[11px] tracking-tight" style="color: var(--color-text-dim);">
              Code, projects, dotfiles.
            </div>
          </div>
          <a
            href={SOCIALS.github}
            target="_blank"
            rel="noreferrer noopener"
            class="font-mono text-[12.5px] tracking-tight transition-colors hover:text-[var(--color-gold)]"
            style="color: var(--color-text);">@rafaelcoelho1409 ↗</a
          >
        </li>
      </ul>
    </section>

    <section
      class="rounded-sm border p-6"
      style="border-color: var(--color-gold-deep); background-color: color-mix(in oklch, var(--color-gold) 4%, var(--color-bg-2));"
    >
      <h2 class="label-mono mb-3" style="color: var(--color-gold);">
        Hiring & relocation
      </h2>
      <p class="text-[14.5px] leading-[1.75]" style="color: var(--color-text);">
        Currently based in {SITE.location}. Open to relocation for Senior / Staff
        MLOps / LLMOps roles in the UAE (Abu Dhabi, Dubai), Saudi Arabia (Riyadh),
        Qatar (Doha), Singapore, or the USA. Also open to fully remote roles globally.
      </p>
    </section>
  </div>
</Base>
