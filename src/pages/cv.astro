---
import Base from "../layouts/Base.astro";
import { CV } from "../data/cv";
import { SITE, SOCIALS } from "../consts";
---

<Base title="CV" description={`CV of ${SITE.author} — Senior MLOps / ML Engineer.`}>
  <div class="container-page">
    <header class="mb-14 pt-4">
      <p class="eyebrow mb-4">/ CV</p>
      <h1
        class="font-display mb-1 text-[2.4rem] font-medium tracking-tight"
        style="color: var(--color-text); letter-spacing: -0.025em;"
      >
        {SITE.author}
      </h1>
      <p class="mb-5 font-mono text-[12px] tracking-[0.14em] uppercase" style="color: var(--color-platinum-dim);">
        {SITE.tagline} · {SITE.location}
      </p>
      <p class="text-[16px] leading-[1.75]" style="color: var(--color-text-muted);">
        {CV.intro}
      </p>

      <div class="mt-6 flex flex-wrap gap-2.5 font-mono text-[12px] tracking-tight">
        <a
          href={SOCIALS.github}
          target="_blank"
          rel="noreferrer noopener"
          class="rounded-sm border px-3 py-1.5 transition-colors hover:border-[var(--color-gold)] hover:text-[var(--color-gold)]"
          style="border-color: var(--color-border-strong); color: var(--color-text);">GitHub ↗</a
        >
      </div>
    </header>

    <div class="hairline-gold mb-12" style="opacity: 0.35;"></div>

    <section class="mb-14">
      <h2 class="label-mono mb-5">Areas of expertise</h2>
      <div class="flex flex-wrap gap-1.5">
        {
          CV.areasOfExpertise.map((a) => (
            <span
              class="inline-flex items-center rounded-full border px-2.5 py-[3px] font-mono text-[10.5px] tracking-tight"
              style="border-color: var(--color-border-strong); background-color: var(--color-bg-2); color: var(--color-text-muted);"
            >
              {a}
            </span>
          ))
        }
      </div>
    </section>

    <section class="mb-14">
      <h2 class="label-mono mb-5">Highlights</h2>
      <ul class="space-y-3.5">
        {
          CV.highlights.map((h) => (
            <li
              class="flex gap-3.5 text-[14.5px] leading-[1.7]"
              style="color: var(--color-text-muted);"
            >
              <span style="color: var(--color-gold);">→</span>
              <span>{h}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mb-14">
      <h2 class="label-mono mb-6">Education</h2>
      <div class="space-y-3">
        {
          CV.education.map((e) => (
            <div>
              <div class="font-display text-[16px]" style="color: var(--color-text);">
                {e.degree}
              </div>
              <div class="font-mono text-[11.5px] tracking-[0.1em] uppercase" style="color: var(--color-platinum-dim);">
                {e.org} · {e.period}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mb-14">
      <h2 class="label-mono mb-5">Languages</h2>
      <ul class="flex flex-wrap gap-x-7 gap-y-2 text-[14px]">
        {
          CV.languages.map((l) => (
            <li style="color: var(--color-text-muted);">
              <span style="color: var(--color-text);">{l.name}</span> · {l.level}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mb-6">
      <h2 class="label-mono mb-5">Interests</h2>
      <div class="flex flex-wrap gap-1.5">
        {
          CV.interests.map((i) => (
            <span
              class="inline-flex items-center rounded-full border px-2.5 py-[3px] font-mono text-[10.5px] tracking-tight"
              style="border-color: var(--color-gold-deep); background-color: color-mix(in oklch, var(--color-gold) 4%, var(--color-bg-2)); color: var(--color-gold-dim);"
            >
              {i}
            </span>
          ))
        }
      </div>
    </section>
  </div>
</Base>
