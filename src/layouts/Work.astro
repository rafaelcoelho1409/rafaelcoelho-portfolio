---
import Base from "./Base.astro";
import StackBadge from "../components/StackBadge.astro";

export interface Props {
  title: string;
  summary: string;
  outcome?: string;
  date: Date;
  stack: string[];
  repo?: string;
  demo?: string;
  paper?: string;
  presentation?: string;
}

const { title, summary, outcome, date, stack, repo, demo, paper, presentation } = Astro.props;

const dateLabel = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
}).format(date);

const links = [
  repo && { label: "Source", href: repo },
  demo && { label: "Live demo", href: demo },
  paper && { label: "Paper", href: paper },
  presentation && { label: "Presentation", href: presentation },
].filter(Boolean) as { label: string; href: string }[];
---

<Base title={title} description={summary} article>
  <article class="container-page">
    <a
      href="/work"
      class="mb-6 inline-flex items-center gap-1 font-mono text-[12px] transition-colors hover:text-[var(--color-accent)]"
      style="color: var(--color-text-dim);"
    >
      ← Work
    </a>

    <header class="mb-10">
      <p class="mb-2 font-mono text-[12px]" style="color: var(--color-accent);">{dateLabel}</p>
      <h1
        class="mb-4 text-3xl font-semibold tracking-tight sm:text-4xl"
        style="color: var(--color-text);"
      >
        {title}
      </h1>
      <p class="text-[16px] leading-7" style="color: var(--color-text-muted);">{summary}</p>

      {outcome && (
        <div
          class="mt-6 rounded-lg border p-4"
          style="border-color: var(--color-accent-dim); background-color: color-mix(in oklch, var(--color-accent) 8%, var(--color-surface));"
        >
          <div
            class="mb-1 font-mono text-[10px] uppercase tracking-wider"
            style="color: var(--color-accent);"
          >
            Outcome
          </div>
          <div class="font-mono text-[13px]" style="color: var(--color-text);">{outcome}</div>
        </div>
      )}

      {stack.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-1.5">
          {stack.map((s) => <StackBadge name={s} />)}
        </div>
      )}

      {links.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-3 font-mono text-[13px]">
          {links.map((l) => (
            <a
              href={l.href}
              target="_blank"
              rel="noreferrer noopener"
              class="rounded border px-3 py-1.5 transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
              style="border-color: var(--color-border-strong); color: var(--color-text);"
            >
              {l.label} ↗
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose-content">
      <slot />
    </div>
  </article>
</Base>
