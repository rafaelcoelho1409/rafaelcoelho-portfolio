---
import { NAV, SITE } from "../consts";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-30 backdrop-blur-md"
  style="background-color: color-mix(in oklch, var(--color-bg) 78%, transparent);"
>
  <div class="container-wide flex h-14 items-center justify-between">
    <a
      href="/"
      class="font-display text-[16px] font-semibold tracking-tight transition-colors hover:text-[var(--color-gold)]"
      style="color: var(--color-text); letter-spacing: -0.02em;"
    >
      Rafael<span style="color: var(--color-gold);">·</span>Coelho
    </a>

    <nav class="flex items-center gap-1 text-[12.5px]" aria-label="Primary">
      {
        NAV.map((item) => {
          const active =
            path === item.href || (item.href !== "/" && path.startsWith(item.href));
          return (
            <a
              href={item.href}
              class="rounded-sm px-2.5 py-1.5 font-medium tracking-tight transition-colors hover:text-[var(--color-text)]"
              style={`color: ${active ? "var(--color-text)" : "var(--color-text-dim)"};`}
              aria-current={active ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
  <div class="hairline-gold"></div>
</header>
