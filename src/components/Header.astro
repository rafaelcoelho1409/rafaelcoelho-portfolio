---
import { NAV, SITE } from "../consts";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-30 border-b backdrop-blur-md" style="border-color: var(--color-border); background-color: color-mix(in oklch, var(--color-bg) 80%, transparent);">
  <div class="container-wide flex h-14 items-center justify-between">
    <a
      href="/"
      class="font-mono text-[13px] tracking-tight transition-colors hover:text-[var(--color-accent)]"
      style="color: var(--color-text);"
    >
      {SITE.title.toLowerCase().replace(" ", "-")}<span style="color: var(--color-accent);">.</span>
    </a>

    <nav class="flex items-center gap-1 text-[13px]" aria-label="Primary">
      {
        NAV.map((item) => {
          const active = path === item.href || (item.href !== "/" && path.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`rounded px-2.5 py-1.5 font-medium transition-colors hover:text-[var(--color-text)]`}
              style={`color: ${active ? "var(--color-text)" : "var(--color-text-dim)"};`}
              aria-current={active ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
