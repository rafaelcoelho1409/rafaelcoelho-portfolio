---
import { NAV } from "../consts";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-30 backdrop-blur-md"
  style="background-color: color-mix(in oklch, var(--color-bg) 78%, transparent);"
>
  <div class="container-wide flex h-14 items-center justify-between">
    <a
      href="/"
      class="font-display font-medium tracking-tight transition-colors hover:text-[var(--color-gold)]"
      style="color: var(--color-text); letter-spacing: -0.018em;"
      aria-label="Rafael Coelho — home"
    >
      <span class="text-[20px]">Rafael</span>
      <span
        class="mx-1.5 align-baseline text-[17px]"
        style="color: var(--color-gold);"
        aria-hidden="true">·</span
      >
      <span
        class="text-[19px] uppercase"
        style="letter-spacing: 0.16em; font-weight: 600;">COELHO</span
      >
    </a>

    <nav class="flex items-center gap-1 text-[12.5px]" aria-label="Primary">
      {
        NAV.map((item) => {
          const active =
            path === item.href ||
            (item.href !== "/" && path.startsWith(item.href));
          return (
            <a
              href={item.href}
              class="rounded-sm px-2.5 py-1.5 font-medium tracking-tight transition-colors hover:text-[var(--color-text)]"
              style={`color: ${active ? "var(--color-text)" : "var(--color-text-dim)"};`}
              aria-current={active ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
  <div class="hairline-gold"></div>
</header>
