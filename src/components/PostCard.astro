---
export interface Props {
  title: string;
  summary: string;
  href: string;
  date: Date;
  tags?: string[];
}

const { title, summary, href, date, tags = [] } = Astro.props;

const dateLabel = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
})
  .format(date)
  .toUpperCase();
---

<a
  href={href}
  class="group block border-b py-6 transition-colors first:border-t"
  style="border-color: var(--color-border);"
>
  <div class="flex items-baseline justify-between gap-4">
    <h3
      class="font-display text-[19px] font-semibold tracking-tight transition-colors group-hover:text-[var(--color-gold)]"
      style="color: var(--color-text); letter-spacing: -0.018em;"
    >
      {title}
    </h3>
    <span
      class="font-mono text-[10.5px] tracking-[0.14em] whitespace-nowrap"
      style="color: var(--color-platinum-dim);"
    >
      {dateLabel}
    </span>
  </div>
  <p class="mt-2.5 text-[14.5px] leading-relaxed" style="color: var(--color-text-muted);">
    {summary}
  </p>
  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2.5">
      {tags.slice(0, 4).map((t) => (
        <span class="font-mono text-[10.5px] tracking-tight" style="color: var(--color-text-dim);">
          #{t}
        </span>
      ))}
    </div>
  )}
</a>
