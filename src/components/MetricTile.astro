---
export interface Props {
  value: string;
  unit?: string;
  label: string;
}
const { value, unit, label } = Astro.props;
---

<div
  class="flex flex-col gap-2.5 rounded-sm border p-5"
  style="border-color: var(--color-border); background-color: var(--color-bg-2);"
>
  <div class="flex items-baseline gap-1.5">
    <span
      class="font-display text-[2.25rem] leading-none font-semibold tracking-tight sm:text-[2.6rem]"
      style="color: var(--color-gold); letter-spacing: -0.03em;">{value}</span
    >
    {unit && (
      <span class="font-mono text-[12px] tracking-tight" style="color: var(--color-platinum-dim);">
        {unit}
      </span>
    )}
  </div>
  <div class="text-[13px] leading-snug" style="color: var(--color-text-muted);">
    {label}
  </div>
</div>
