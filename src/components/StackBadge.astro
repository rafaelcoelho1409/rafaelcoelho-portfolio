---
export interface Props {
  name: string;
}
const { name } = Astro.props;
---

<span
  class="inline-flex items-center rounded-full border px-2.5 py-[3px] font-mono text-[10.5px] tracking-tight"
  style="border-color: var(--color-border); background-color: var(--color-bg-2); color: var(--color-platinum-dim);"
>
  {name}
</span>
