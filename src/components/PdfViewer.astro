---
export interface Props {
  src: string;
  height?: string;
  ariaLabel?: string;
  downloadLabel?: string;
}

const {
  src,
  height = "78vh",
  ariaLabel = "PDF viewer",
  downloadLabel = "Download PDF",
} = Astro.props;
---

<div class="pdf-viewer-wrap">
  <div
    class="pdf-viewer-container rounded-sm border"
    data-pdf-src={src}
    style={`height: ${height}; border-color: var(--color-gold-deep); background-color: var(--color-bg-2);`}
    role="region"
    aria-label={ariaLabel}
  >
    <div
      class="pdf-viewer-placeholder"
      style="display: flex; align-items: center; justify-content: center; height: 100%; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-platinum-dim);"
    >
      <span data-pdf-placeholder>Loading viewer…</span>
    </div>
  </div>
  <div class="mt-3 flex justify-end">
    <a
      href={src}
      target="_blank"
      rel="noreferrer noopener"
      class="font-mono text-[11px] tracking-[0.14em] uppercase transition-colors hover:text-[var(--color-gold)]"
      style="color: var(--color-platinum-dim);"
    >
      {downloadLabel} ↗
    </a>
  </div>
</div>

<style is:global>
  .pdf-viewer-container > :not(.pdf-viewer-placeholder) {
    border-radius: 1px;
  }
  .pdf-viewer-container iframe,
  .pdf-viewer-container > div:not(.pdf-viewer-placeholder) {
    width: 100% !important;
    height: 100% !important;
  }
</style>

<script is:inline type="module">
  function initPdfViewers() {
    const targets = document.querySelectorAll(
      "[data-pdf-src]:not([data-pdf-init])",
    );
    if (targets.length === 0) return;
    import(
      "https://cdn.jsdelivr.net/npm/@embedpdf/snippet@2/dist/embedpdf.js"
    )
      .then(({ default: EmbedPDF }) => {
        targets.forEach((el) => {
          if (el.dataset.pdfInit === "1") return;
          el.dataset.pdfInit = "1";
          const placeholder = el.querySelector("[data-pdf-placeholder]");
          if (placeholder) placeholder.textContent = "Initializing…";
          try {
            EmbedPDF.init({
              type: "container",
              target: el,
              src: el.dataset.pdfSrc,
            });
            const inner = el.querySelector(".pdf-viewer-placeholder");
            if (inner) inner.remove();
          } catch (err) {
            console.error("[PdfViewer] init failed", err);
            if (placeholder)
              placeholder.textContent =
                "Viewer unavailable — use download link below.";
          }
        });
      })
      .catch((err) => {
        console.error("[PdfViewer] failed to load EmbedPDF", err);
        targets.forEach((el) => {
          const placeholder = el.querySelector("[data-pdf-placeholder]");
          if (placeholder)
            placeholder.textContent =
              "Viewer unavailable — use download link below.";
        });
      });
  }

  initPdfViewers();
  document.addEventListener("astro:page-load", initPdfViewers);
</script>
