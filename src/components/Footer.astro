---
import { SITE, SOCIALS } from "../consts";

const year = 2026;
---

<footer class="mt-12">
  <div class="hairline-gold"></div>
  <div
    class="container-wide flex flex-col gap-3 py-8 text-[12.5px] sm:flex-row sm:items-center sm:justify-between"
  >
    <div
      class="font-mono tracking-tight"
      style="color: var(--color-text-dim);"
    >
      © {year}&nbsp;&nbsp;·&nbsp;&nbsp;Rafael <span
        class="uppercase"
        style="letter-spacing: 0.16em; color: var(--color-platinum);">COELHO</span
      >&nbsp;&nbsp;·&nbsp;&nbsp;{SITE.location}
    </div>
    <nav class="flex items-center gap-5" aria-label="Social">
      <a
        href={SOCIALS.github}
        target="_blank"
        rel="noreferrer noopener"
        class="font-mono tracking-tight transition-colors hover:text-[var(--color-gold)]"
        style="color: var(--color-platinum-dim);"
      >
        GitHub
      </a>
      <a
        href={SOCIALS.linkedin}
        target="_blank"
        rel="noreferrer noopener"
        class="font-mono tracking-tight transition-colors hover:text-[var(--color-gold)]"
        style="color: var(--color-platinum-dim);"
      >
        LinkedIn
      </a>
      <a
        href={SOCIALS.email}
        class="font-mono tracking-tight transition-colors hover:text-[var(--color-gold)]"
        style="color: var(--color-platinum-dim);"
      >
        Email
      </a>
      <a
        href="/rss.xml"
        class="font-mono tracking-tight transition-colors hover:text-[var(--color-gold)]"
        style="color: var(--color-platinum-dim);"
      >
        RSS
      </a>
    </nav>
  </div>
</footer>
