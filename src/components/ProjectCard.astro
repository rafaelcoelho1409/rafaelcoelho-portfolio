---
import StackBadge from "./StackBadge.astro";

export interface Props {
  title: string;
  summary: string;
  outcome?: string;
  href: string;
  stack: string[];
  date: Date;
  featured?: boolean;
}

const { title, summary, outcome, href, stack, date, featured = false } = Astro.props;

const dateLabel = new Intl.DateTimeFormat("en-US", {
  month: "short",
  year: "numeric",
}).format(date);

const visibleStack = stack.slice(0, 6);
const restCount = Math.max(0, stack.length - visibleStack.length);
---

<a
  href={href}
  class="group block rounded-lg border p-5 transition-colors hover:bg-[color-mix(in_oklch,var(--color-surface)_70%,var(--color-bg))]"
  style={`border-color: ${featured ? "var(--color-border-strong)" : "var(--color-border)"}; background-color: var(--color-surface);`}
>
  <div class="mb-3 flex items-center justify-between gap-3">
    <div class="flex items-center gap-2">
      <h3
        class="text-[15px] font-semibold tracking-tight transition-colors group-hover:text-[var(--color-accent)]"
        style="color: var(--color-text);"
      >
        {title}
      </h3>
      {featured && (
        <span
          class="rounded-full border px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider"
          style="border-color: var(--color-accent-dim); color: var(--color-accent);"
        >
          Flagship
        </span>
      )}
    </div>
    <span class="font-mono text-[11px] whitespace-nowrap" style="color: var(--color-text-dim);">
      {dateLabel}
    </span>
  </div>

  <p class="mb-4 text-[14px] leading-relaxed" style="color: var(--color-text-muted);">
    {summary}
  </p>

  {outcome && (
    <p class="mb-4 border-l-2 pl-3 font-mono text-[12.5px]" style="border-color: var(--color-accent); color: var(--color-text);">
      {outcome}
    </p>
  )}

  <div class="flex flex-wrap items-center gap-1.5">
    {visibleStack.map((s) => <StackBadge name={s} />)}
    {restCount > 0 && (
      <span class="font-mono text-[11px]" style="color: var(--color-text-dim);">
        +{restCount} more
      </span>
    )}
  </div>
</a>
