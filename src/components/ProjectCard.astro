---
import StackBadge from "./StackBadge.astro";

export interface Props {
  title: string;
  summary: string;
  outcome?: string;
  href: string;
  stack: string[];
  date: Date;
  featured?: boolean;
  thumbnail?: string;
  eager?: boolean;
}

const {
  title,
  summary,
  outcome,
  href,
  stack,
  date,
  featured = false,
  thumbnail,
  eager = false,
} = Astro.props;

const dateLabel = new Intl.DateTimeFormat("en-US", {
  month: "short",
  year: "numeric",
})
  .format(date)
  .toUpperCase();

const visibleStack = stack.slice(0, 6);
const restCount = Math.max(0, stack.length - visibleStack.length);
---

<a
  href={href}
  class="group block overflow-hidden rounded-sm border transition-colors hover:bg-[color-mix(in_oklch,var(--color-bg-2)_75%,var(--color-bg))]"
  style={`border-color: ${featured ? "var(--color-gold-deep)" : "var(--color-border)"}; background-color: var(--color-bg-2);`}
>
  {thumbnail && (
    <div
      class="relative overflow-hidden"
      style="background-color: oklch(0.08 0 0);"
    >
      <img
        src={thumbnail}
        alt={`${title} logo`}
        class="mx-auto block"
        style="height: 116px; max-width: 90%; object-fit: contain; object-position: center;"
        loading={eager ? "eager" : "lazy"}
        decoding="async"
      />
      <div
        class="absolute inset-x-0 bottom-0 h-px"
        style="background: linear-gradient(to right, transparent, var(--color-gold-deep) 25%, var(--color-gold) 50%, var(--color-gold-deep) 75%, transparent); opacity: 0.55;"
      ></div>
    </div>
  )}
  <div class="p-6">
    <div class="mb-4 flex items-baseline justify-between gap-3">
      <div class="flex items-center gap-3">
        <h3
          class="font-display text-[20px] font-semibold tracking-tight transition-colors group-hover:text-[var(--color-gold)]"
          style="color: var(--color-text); letter-spacing: -0.018em;"
        >
          {title}
        </h3>
        {featured && (
          <span
            class="rounded-full border px-2 py-[2px] font-mono text-[9.5px] tracking-[0.16em] uppercase"
            style="border-color: var(--color-gold-deep); color: var(--color-gold);"
          >
            Flagship
          </span>
        )}
      </div>
      <span
        class="font-mono text-[10.5px] tracking-[0.14em] whitespace-nowrap"
        style="color: var(--color-platinum-dim);"
      >
        {dateLabel}
      </span>
    </div>

    <p
      class="mb-5 text-[14.5px] leading-relaxed"
      style="color: var(--color-text-muted);"
    >
      {summary}
    </p>

    {outcome && (
      <div
        class="mb-5 border-l py-1 pl-4 font-mono text-[12.5px] leading-relaxed"
        style="border-color: var(--color-gold); color: var(--color-text);"
      >
        {outcome}
      </div>
    )}

    <div class="flex flex-wrap items-center gap-1.5">
      {visibleStack.map((s) => <StackBadge name={s} />)}
      {restCount > 0 && (
        <span class="font-mono text-[10.5px] tracking-tight" style="color: var(--color-text-dim);">
          +{restCount} more
        </span>
      )}
    </div>
  </div>
</a>
